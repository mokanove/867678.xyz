---
import '../styles/sidebar.css';
import pkg from '../../package.json';
const { version } = pkg;
const ProjectOptions = "font-bold text-[var(--text-main)] hover:text-blue-300 focus:text-blue-400 transition-colors outline-none";
---

<script define:vars={{ version }} is:inline>
  const t = localStorage.getItem('theme') || 
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
  document.documentElement.classList.toggle('dark', t === 'dark');
</script>

<aside class="h-screen bg-[var(--bg-aside)] flex flex-col transition-colors duration-500 overflow-hidden border-r border-[var(--border-color)]">
    
    <div class="p-8 pb-4 flex flex-col items-center flex-shrink-0">
        <a href="/"><img src="/favicon.svg" class="w-32 h-32 rounded-3xl" /></a>
        <h1 class="text-4xl font-black mt-4 text-[var(--text-title)] text-center">Mo Kanove</h1>
        <p class="text-blue-500">An open source developer</p>
    </div>

    <hr class="mx-8 border-[var(--border-color)] flex-shrink-0" />

    <nav class="flex-1 overflow-y-auto p-8 pt-6 custom-scrollbar flex flex-col gap-10">
        <div class="flex flex-col gap-5">
            <h3 class="text-1xl font-black text-blue-400 border-l-4 border-blue-400 pl-3">Web Tools</h3>
            <div class="flex flex-col gap-3">
                <a href="#" class={ProjectOptions}>MoITools</a>
                <a href="#" class={ProjectOptions}>TkkHs</a>
            </div>
        </div>

        <div class="flex flex-col gap-5">
            <h3 class="text-1xl font-black text-blue-400 border-l-4 border-blue-400 pl-3">OpenWrt Apps</h3>
            <div class="flex flex-col gap-3">
                <a href="#" class={ProjectOptions}>LuCI-APP-OpList</a>
                <a href="#" class={ProjectOptions}>RDKS</a>
                <a href="#" class={ProjectOptions}>LuCI-APP-Powermanager</a>
            </div>
        </div>

        <div class="flex flex-col gap-5">
            <h3 class="text-1xl font-black text-blue-400 border-l-4 border-blue-400 pl-3">Document</h3>
            <div class="flex flex-col gap-3">
                <a href="#" class={ProjectOptions}>Initialize ImmortalWrt development SDK</a>
                <a href="#" class={ProjectOptions}>Install OpenWrt App</a>
                <a href="#" class={ProjectOptions}>Make OpenWrt App</a>
            </div>
        </div>
    </nav>
<div class="flex-shrink-0 w-full flex justify-center py-6">
  <div class="relative w-44 h-8 bg-gray-200 dark:bg-slate-800 rounded-lg p-1 flex items-center transition-colors duration-300">
    <div id="theme-slider" class="absolute left-1 w-[calc(33.33%-2.6px)] h-[calc(100%-8px)] bg-white dark:bg-blue-600 rounded-md shadow-sm transition-transform duration-300 ease-in-out pointer-events-none"></div>
    <button data-theme-val="system" class="z-10 flex-1 h-full flex justify-center items-center text-[10px] cursor-pointer">
      <span>🖥️</span>
    </button>
    <button data-theme-val="light" class="z-10 flex-1 h-full flex justify-center items-center text-[10px] cursor-pointer">
      <span>☀️</span>
    </button>
    <button data-theme-val="dark" class="z-10 flex-1 h-full flex justify-center items-center text-[10px] cursor-pointer">
      <span>🌙</span>
    </button>
  </div>
</div>
</aside>

<script>
import { initTheme } from '../scripts/theme';
initTheme();
document.addEventListener('astro:after-swap', initTheme);
</script>