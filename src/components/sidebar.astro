---
//css
import '../styles/sidebar.css';
---
<div class="sidebar">
    <div class="header">
        <div class="avatar-container">
            <img src="/favicon.svg" alt="Logo">
        </div>
            <h2>MoKanove</h2>
            <p>A dumb , an asshole freedom programmer.</p>
    </div>
<div class="sidebar">
  <nav class="section">
    <h3 class="section-label">Web Projects</h3>
    <div class="list">
      <button class="item" data-target="moitools">MoITools</button>
      <button class="item" data-target="tkkhs">TKKHS</button>
    </div>
  </nav>

  <nav class="section">
    <h3 class="section-label">Program</h3>
    <div class="list">
      <button class="item runnable" data-target="content-oplist">
        <span class="status-icon"></span>LuCI-APP-OPList
      </button>
      <button class="item runnable" data-target="content-pm">
        <span class="status-icon"></span>LuCI-APP-PM
      </button>
      <button class="item runnable" data-target="content-rdks">
        <span class="status-icon"></span>RDKS
      </button>
    </div>
  </nav>

  <nav class="section">
    <h3 class="section-label">Documents</h3>
    <div class="list">
      <button class="item doc" data-target="doc-install">Install OpenWrt App</button>
      <button class="item doc" data-target="doc-build">Build OpenWrt APP</button>
      <button class="item doc" data-target="doc-init">Init OpenWrt SDK</button>
      <button class="item doc" data-target="doc-site">Build this site</button>
    </div>
  </nav>

  <nav class="section">
    <h3 class="section-label">Theme</h3>
    <div class="list">
      <button class="item runnable" data-theme="light">
        <span class="status-icon"></span>Light
      </button>
      <button class="item runnable" data-theme="dark">
        <span class="status-icon"></span>Dark
      </button>
      <button class="item runnable" data-theme="auto">
        <span class="status-icon"></span>Auto
      </button>
    </div>
  </nav>
</div>