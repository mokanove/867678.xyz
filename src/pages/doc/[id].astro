---
//css
import { marked } from 'marked';
import IndexPage from '../index.astro';
//md
const { url, title } = Astro.props;
const res = await fetch(url);
const content = await marked.parse(await res.text());
export async function getStaticPaths() {
  const projects = [
    {id:'Mirror',title:'Mirrors List',url:'https://raw.githubusercontent.com/mokanove/mokanove/refs/heads/main/doc/mirror.md'},
    {id:'OpenWrt',title:'Anything about OpenWrt',url:'https://raw.githubusercontent.com/mokanove/mokanove/refs/heads/main/doc/openwrt.md'},
    {id:'bts',title:'How to build this site',url:'https://raw.githubusercontent.com/mokanove/867678.xyz/refs/heads/main/README.md'},
    {id:'MoPL',title:'Mo Pubilc License',url:'https://raw.githubusercontent.com/mokanove/mokanove/refs/heads/main/doc/license.md'},
  ];
  return projects.map(({ id, ...props }) => ({
    params: { id },
    props,
  }));
}
---
<IndexPage title={title} childpage={true}>
  <article class="markdown-body" set:html={content} />
</IndexPage>