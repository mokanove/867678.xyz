---
import { marked } from 'marked';
import IndexPage from '../index.astro';

export async function getStaticPaths() {
  const DOC_SOURCES = {
    'init': 'https://raw.githubusercontent.com/mokanove/mokanove/refs/heads/main/docs/init-sdk.md',
    'build': 'https://raw.githubusercontent.com/mokanove/mokanove/refs/heads/main/docs/build-op.md',
    'site': 'https://raw.githubusercontent.com/mokanove/867678.xyz/refs/heads/main/README.md',
    'license': 'https://raw.githubusercontent.com/mokanove/867678.xyz/refs/heads/main/LICENSE.md'
  };

  return Object.entries(DOC_SOURCES).map(([id, url]) => ({ params: { id }, props: { url } }));
}

const { id } = Astro.params;
const { url } = Astro.props;
const res = await fetch(url);
const content = await marked.parse(await res.text());

const fullId = `doc-${id}`;
---
<IndexPage title={id} activeId={fullId} isChild={true}>
  <article class="markdown-body" set:html={content} />
</IndexPage>