---
//css
import '../../style/page.css';
//components
import { marked } from 'marked';
import IndexPage from '../index.astro';
//const
const { id } = Astro.params;
const { url } = Astro.props;
const res = await fetch(url);
const content = await marked.parse(await res.text());
//markdown
export async function getStaticPaths() {
  const project_markdown = {
  'go-rustdesk-server': 'https://raw.githubusercontent.com/mokanove/go-rustdesk-server/main/README.md',
  'luci-app-ezsgx': 'https://raw.githubusercontent.com/mokanove/luci-app-ezsgx/main/README.md',
  'luci-app-oplist': 'https://raw.githubusercontent.com/mokanove/luci-app-oplist/main/README.md',
  'luci-app-pm': 'https://raw.githubusercontent.com/mokanove/luci-app-pm/main/README.md',
  };
  return Object.entries(project_markdown).map(([id, url]) => ({ params: { id }, props: { url } }));
}
---
<IndexPage title={id} childpage={true}>
  <article class="markdown-body" set:html={content} />
</IndexPage>