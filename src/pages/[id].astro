---
import IndexPage from './index.astro';
import '../styles/pages.css';
import { marked } from 'marked';
import 'github-markdown-css/github-markdown.css';

export async function getStaticPaths() {
  const MD_SOURCES = {
  'oplist': 'https://raw.githubusercontent.com/mokanove/luci-app-oplist/main/README.md',
  'pm': 'https://raw.githubusercontent.com/mokanove/luci-app-pm/main/README.md',
  'rdks': 'https://raw.githubusercontent.com/mokanove/rdks/main/README.md',
  'doc-init': 'https://raw.githubusercontent.com/mokanove/mokanove/refs/heads/main/docs/init-sdk.md',
  'doc-build': 'https://raw.githubusercontent.com/mokanove/mokanove/refs/heads/main/docs/build-op.md',
  'doc-site': 'https://raw.githubusercontent.com/mokanove/867678.xyz/refs/heads/main/README.md'
  };
  return Object.entries(MD_SOURCES).map(([id, url]) => ({ params: { id }, props: { url } }));
}

const { id } = Astro.params;
const { url } = Astro.props;
const res = await fetch(url);
const content = await marked.parse(await res.text());
---
<IndexPage title={id} activeId={id} isChild={true}>
  <article class="markdown-body" set:html={content} />
</IndexPage>